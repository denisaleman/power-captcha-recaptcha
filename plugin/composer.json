{
  "name": "denisaleman/pwrcap",
  "description": "Google reCAPTCHA integration for WordPress and WooCommerce.",
  "type": "wordpress-plugin",
  "version": "1.3.0",
  "authors": [
    {
      "name": "Denis Alemán",
      "email": "denis@denisaleman.com"
    }
  ],
  "license": "GPL-3.0-only",
  "require": {
    "php": ">=5.5",
    "google/recaptcha": "1.2.4"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "*",
    "phpcompatibility/phpcompatibility-wp": "*",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "sirbrillig/phpcs-variable-analysis": "^2.11",
    "ext-tokenizer": "*",
    "ext-xmlwriter": "*",
    "ext-simplexml": "*"
  },
  "scripts": {
    "post-install-cmd": "\"./vendor/bin/phpcs\" --config-set installed_paths ../../phpcompatibility/php-compatibility,../../phpcompatibility/phpcompatibility-paragonie,../../phpcompatibility/phpcompatibility-wp,../../sirbrillig/phpcs-variable-analysis,../../wp-coding-standards/wpcs",
    "post-update-cmd": "\"./vendor/bin/phpcs\" --config-set installed_paths ../../phpcompatibility/php-compatibility,../../phpcompatibility/phpcompatibility-paragonie,../../phpcompatibility/phpcompatibility-wp,../../sirbrillig/phpcs-variable-analysis,../../wp-coding-standards/wpcs"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
